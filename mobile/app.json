{
  "expo": {
    "name": "Memu",
    "slug": "memu",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "memu",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5054B5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "digital.memu.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Memu uses the camera so you can send photos of notes, newsletters, and documents for Memu to read.",
        "NSPhotoLibraryUsageDescription": "Memu reads photos you choose so it can extract tasks and events from notes, newsletters, and documents."
      }
    },
    "android": {
      "package": "digital.memu.app",
      "usesCleartextTraffic": true,
      "permissions": [
        "INTERNET",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#5054B5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundImage": "./assets/android-icon-background.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04b800c3-f5fa-43be-84cd-07077f1515f8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/04b800c3-f5fa-43be-84cd-07077f1515f8"
    }
  }
}
