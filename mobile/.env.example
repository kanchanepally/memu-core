# ==========================================================
# Memu Mobile — environment variables
# Copy to `.env`:  cp .env.example .env
#
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time
# (not secret). Use eas.json `env` for production builds.
# ==========================================================

# ---------- Backend ----------
# Baked server URL — when set, the onboarding flow skips the "enter
# server address" step. Use your Tailscale hostname for home builds.
# EXPO_PUBLIC_API_URL=http://memu-hub:3100

# ---------- Google Sign-In (OIDC) ----------
# Client IDs from Google Cloud Console → Credentials.
# Create three clients (same project):
#   iOS      — type "iOS",      bundle id = com.memu.app
#   Android  — type "Android",  package   = com.memu.app + SHA-1
#   Web      — type "Web",      used by Expo Go dev flow + web bundle
# The backend verifies the returned ID token against these same IDs
# (see backend .env: GOOGLE_IOS_CLIENT_ID / ANDROID / WEB).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
