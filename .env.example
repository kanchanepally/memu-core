# Server
PORT=3100
TZ=Europe/London
ADMIN_WHATSAPP_NUMBER=447000000000

# Database (PostgreSQL)
# Standalone: postgresql://memu:password@db:5432/memu_core
# Home: postgresql://memu_user:password@memu_postgres:5432/memu_core
DATABASE_URL=postgresql://memu:password@localhost:5432/memu_core
DB_PASSWORD=password

# AI Configuration
# LLM Providers
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Calendar Integration (Slice 2c)
# Configure an OAuth App in Google Cloud Console
# Homepage: http://localhost:3100
# Callback URI: http://localhost:3100/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3100/api/auth/google/callback

OLLAMA_HOST=http://localhost:11434

# Features Observers Config
ENABLE_CALENDAR=false
ENABLE_EMAIL=false
ENABLE_PHOTOS=false

# Home Server Integrations (Tier 2)
IMMICH_API_KEY=
CALDAV_USERNAME=
CALDAV_PASSWORD=
