# ==========================================================
# Memu Core — environment variables
# Copy to `.env`:   cp .env.example .env
# Then fill in the REQUIRED values before running docker compose.
# ==========================================================

# ---------- Server ----------
PORT=3100
TZ=Europe/London
LOG_LEVEL=info

# ---------- Database (PostgreSQL + pgvector) ----------
# Standalone dev:  postgresql://memu:password@localhost:5432/memu_core
# HP Z2 / home:    postgresql://memu_user:${DB_PASSWORD}@memu_postgres:5432/memu_core
#                  (docker-compose.home.yml builds the URL from DB_PASSWORD)
DATABASE_URL=postgresql://memu:password@localhost:5432/memu_core
DB_PASSWORD=change-me-to-a-strong-password

# ---------- LLM provider (deprecated — the model router now picks per skill) ----------
# Story 1.1: every LLM call is routed by src/skills/router.ts based on each
# skill's `model` frontmatter. MEMU_LLM_PROVIDER is no longer consulted.
# To substitute local models for a whole alias (e.g. Tier 3 / Ollama):
#   MEMU_MODEL_OVERRIDE_HAIKU=local
#   MEMU_MODEL_OVERRIDE_SONNET=local
# To apply budget-pressure downgrades (premium→haiku, standard sonnet→haiku):
#   MEMU_BUDGET_PRESSURE=true
# Concrete provider models are env-overridable:
#   MEMU_CLAUDE_HAIKU_MODEL, MEMU_CLAUDE_SONNET_MODEL,
#   MEMU_GEMINI_FLASH_MODEL, MEMU_GEMINI_FLASH_LITE_MODEL, MEMU_OLLAMA_MODEL

# ---------- Claude API (used when MEMU_LLM_PROVIDER=claude) ----------
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------- Twin guard (Story 1.4) — runtime invariant enforcement ----------
# The Digital Twin guard checks every outbound LLM call for skills with
# `requires_twin: true` and refuses to leak real entity names.
#   throw              : refuse to dispatch, raise an error (dev default)
#   log_and_anonymize  : auto-translate leaking fields, proceed, log violation (prod default)
#   off                : no-op (NOT recommended — kills the privacy guarantee)
# Leave unset to use the environment-based default.
MEMU_TWIN_GUARD_MODE=

# ---------- Twin novel-entity detection (Story 1.5) ----------
# When an inbound message mentions a person/place/institution the Twin registry
# hasn't seen, the `twin_translate` skill (model: local) extracts proper nouns
# and auto-registers them before translation. Modes:
#   auto    : detect + register automatically (default)
#   prompt  : detect + hold pending family approval (not yet implemented)
#   off     : skip detection entirely
# Tier 2 note: `twin_translate` is `model: local`. Without Ollama, set
#   MEMU_MODEL_OVERRIDE_LOCAL=haiku
# to route novel-entity extraction to Claude Haiku as a cloud fallback.
MEMU_TWIN_NOVEL_MODE=auto

# ---------- BYOK — encryption key for per-user Anthropic keys ----------
# Story 1.2: adults can paste their own Anthropic API key in the mobile app.
# Keys are stored AES-256-GCM encrypted in profile_provider_keys. This is the
# master key. Generate with:   openssl rand -base64 32
# If unset, BYOK is unavailable and the deployment ANTHROPIC_API_KEY is used.
MEMU_BYOK_ENCRYPTION_KEY=

# ---------- Gemini API ----------
# Get a key at https://aistudio.google.com/apikey
# GEMINI_MODEL is optional — defaults to gemini-2.5-flash. Use
# gemini-2.5-pro for heavier reasoning (tighter free-tier quota).
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ---------- OPTIONAL: Google Calendar ----------
# Only needed if you want the Today screen to show calendar events.
# Create an OAuth client at https://console.cloud.google.com
#   Authorised JS origin:  http://memu-hub:3100
#   Authorised redirect:   http://memu-hub:3100/api/auth/google/callback
# (Use your Tailscale hostname or LAN IP — the redirect URI must match exactly.)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://memu-hub:3100/api/auth/google/callback

# ---------- OPTIONAL: Google Sign-In (OIDC) ----------
# Accepted audiences when verifying ID tokens from the mobile app.
# Create separate OAuth clients in Google Cloud Console for each platform:
#   iOS:     type "iOS"      — bundle id = com.memu.app
#   Android: type "Android"  — package  = com.memu.app + SHA-1 fingerprint
#   Web:     type "Web application" — used by Expo web + Expo Go dev flow
# GOOGLE_CLIENT_ID above is also accepted as an audience.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# ---------- OPTIONAL: existing memu-suite services ----------
# Consumed by docker-compose.home.yml. The observers that read these are
# feature-flagged off for the household beta — leave blank unless you're
# wiring up Immich / Baikal observers.
OLLAMA_HOST=http://memu_brain:11434
IMMICH_API_KEY=
CALDAV_USERNAME=
CALDAV_PASSWORD=

# ---------- OPTIONAL: feature flags ----------
# Keep these off for the household beta — the mobile app is the primary channel.
ENABLE_CALENDAR=false
ENABLE_EMAIL=false
ENABLE_PHOTOS=false

# ---------- OPTIONAL: WhatsApp bot ----------
# Your personal WhatsApp number in international format (no + or spaces)
# Used to recognise the admin in the Baileys-based WhatsApp channel (optional).
ADMIN_WHATSAPP_NUMBER=447000000000
