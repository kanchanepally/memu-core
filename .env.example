# ==========================================================
# Memu Core — environment variables
# Copy to `.env`:   cp .env.example .env
# Then fill in the REQUIRED values before running docker compose.
# ==========================================================

# ---------- Server ----------
PORT=3100
TZ=Europe/London
LOG_LEVEL=info

# ---------- Database (PostgreSQL + pgvector) ----------
# Standalone dev:  postgresql://memu:password@localhost:5432/memu_core
# HP Z2 / home:    postgresql://memu_user:${DB_PASSWORD}@memu_postgres:5432/memu_core
#                  (docker-compose.home.yml builds the URL from DB_PASSWORD)
DATABASE_URL=postgresql://memu:password@localhost:5432/memu_core
DB_PASSWORD=change-me-to-a-strong-password

# ---------- REQUIRED: Claude API ----------
# Powers the AI pipeline (chat, import, auto-learn).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------- OPTIONAL: Google Calendar ----------
# Only needed if you want the Today screen to show calendar events.
# Create an OAuth client at https://console.cloud.google.com
#   Authorised JS origin:  http://memu-hub:3100
#   Authorised redirect:   http://memu-hub:3100/api/auth/google/callback
# (Use your Tailscale hostname or LAN IP — the redirect URI must match exactly.)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://memu-hub:3100/api/auth/google/callback

# ---------- OPTIONAL: existing memu-suite services ----------
# Consumed by docker-compose.home.yml. The observers that read these are
# feature-flagged off for the household beta — leave blank unless you're
# wiring up Immich / Baikal observers.
OLLAMA_HOST=http://memu_brain:11434
IMMICH_API_KEY=
CALDAV_USERNAME=
CALDAV_PASSWORD=

# ---------- OPTIONAL: feature flags ----------
# Keep these off for the household beta — the mobile app is the primary channel.
ENABLE_CALENDAR=false
ENABLE_EMAIL=false
ENABLE_PHOTOS=false

# ---------- OPTIONAL: WhatsApp bot ----------
# Your personal WhatsApp number in international format (no + or spaces)
# Used to recognise the admin in the Baileys-based WhatsApp channel (optional).
ADMIN_WHATSAPP_NUMBER=447000000000
