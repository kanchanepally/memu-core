# ==========================================================
# Memu Core — STANDALONE environment (B-live, HP Z2)
#
# This is the env template for the STANDALONE deployment profile
# (docker-compose.standalone.yml). For the future DOCKED profile
# (docker-compose.home.yml), use .env.example instead.
#
# On the Z2:
#   cp .env.standalone.example .env
#   nano .env    # fill the CHANGE_ME lines
#   docker compose -f docker-compose.standalone.yml up -d --build
#
# Any time a new required env var is added to this file, the runbook
# (memu-build-plan.md §9.1) says: diff your .env against this template
# before the next `docker compose up -d --build` to prevent crash-loops.
# ==========================================================

# ---------- Server ----------
TZ=Europe/London
LOG_LEVEL=info

# Tailnet hostname for the Z2. Used by the mobile app as the backend URL,
# by Google OAuth redirect, and by the Solid-OIDC WebID issuer. Change if
# you're running behind a different hostname.
PUBLIC_BASE_URL=http://memu-hub:3100

# ---------- Database ---------- REQUIRED
# Generate with:  openssl rand -base64 24
DB_PASSWORD=CHANGE_ME

# ---------- LLM providers ---------- REQUIRED for chat
# Anthropic (adult chat, synthesis, briefing, vision):
#   https://console.anthropic.com
ANTHROPIC_API_KEY=CHANGE_ME
# Gemini (extraction skill per Milestone A3):
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-flash

# ---------- Twin guard (Story 1.4) ----------
# Production default: log_and_anonymize — auto-translate leaks and proceed,
# log the violation to privacy_ledger so you can inspect. Alternative: throw
# (block dispatch entirely — use in dev). Never set to `off` in production.
MEMU_TWIN_GUARD_MODE=log_and_anonymize
MEMU_TWIN_NOVEL_MODE=auto

# ---------- BYOK encryption key ---------- REQUIRED
# Encrypts per-user Anthropic keys at rest.
# Generate with:  openssl rand -base64 32
# Losing this key means adults must re-enter their BYOK keys.
MEMU_BYOK_ENCRYPTION_KEY=CHANGE_ME

# ---------- Model routing ----------
# twin_translate skill is `model: local`. Without Ollama on standalone,
# route it to Haiku. (The compose file defaults this to `haiku` if unset.)
MEMU_MODEL_OVERRIDE_LOCAL=haiku

# ---------- Identity (Solid-OIDC + WebID) ----------
# Should equal PUBLIC_BASE_URL so WebIDs issued match the callable server.
MEMU_WEBID_BASE_URL=http://memu-hub:3100
# Cookie signing keys — the app warns loudly if this is unset and uses a
# weak default. Generate with:  openssl rand -base64 32
MEMU_OIDC_COOKIE_KEYS=CHANGE_ME

# ---------- OPTIONAL: Google Calendar ----------
# Fill in only if the Today screen should show Google Calendar events.
# Create an OAuth client at https://console.cloud.google.com
#   Authorised JS origin:  http://memu-hub:3100
#   Authorised redirect:   http://memu-hub:3100/api/auth/google/callback
# The redirect URI below must EXACTLY match the one in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://memu-hub:3100/api/auth/google/callback

# ---------- OPTIONAL: Google Sign-In (OIDC) ----------
# Accepted audiences when verifying ID tokens from the mobile app.
# GOOGLE_CLIENT_ID above is also accepted as an audience.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# ---------- OPTIONAL: WhatsApp (Baileys, B-live-5) ----------
# Hareesh's personal WhatsApp number, international format, no + or spaces.
# Recognises you as the admin in the WhatsApp channel once Baileys is paired.
ADMIN_WHATSAPP_NUMBER=

# ---------- Observers (off for personal-use beta) ----------
ENABLE_CALENDAR=false
ENABLE_EMAIL=false
ENABLE_PHOTOS=false
